# Example environment variables for GenFlex demo
# Copy this file to `.env` and fill in your values.

# Google Cloud project and location
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Optional: name of a Cloud Storage bucket to store logs/artifacts
LOGS_BUCKET_NAME=your-logs-bucket

# Gemini model override (defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Route ADK through Vertex AI instead of the public Gemini API (avoids free-tier quota limits)
GOOGLE_GENAI_USE_VERTEXAI=true

# ADK / Gemini authentication settings (if using API key instead of ADC)
#GOOGLE_API_KEY=your_api_key

# Log file
LOG_FILE=logs/app.log

# Agent Identity for Agent Engine (set to true to enable)
AGENT_IDENTITY=true
